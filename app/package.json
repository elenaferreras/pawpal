{
  "name": "pawpal",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "PawPal — mobile-first dog care PWA, React 19 architecture",
  "scripts": {
    "dev": "vite",
    "build:ui": "tsc -p tsconfig.json --noEmit && vite build",
    "build:sw": "tsc -p tsconfig.worker.json --noEmit && esbuild src/code.ts --bundle --format=iife --target=es2020 --outfile=dist/code.js",
    "build:manifest": "node -e \"require('fs').mkdirSync('dist',{recursive:true});require('fs').copyFileSync('public/manifest.json','dist/manifest.json')\"",
    "build": "npm run build:ui && npm run build:sw && npm run build:manifest",
    "preview": "vite preview",
    "deploy": "npm run build && cp dist/ui.html ../index.html && cp dist/code.js ../code.js && cp dist/manifest.json ../manifest.json && cp dist/*.png ../ && git -C .. add -A && git -C .. commit -m \"chore: deploy build\" && git -C .. push origin main",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.worker.json --noEmit"
  },
  "dependencies": {
    "@astryxdesign/core": "^0.1.6",
    "@astryxdesign/theme-butter": "^0.1.6",
    "@astryxdesign/theme-neutral": "^0.1.6",
    "@stylexjs/stylex": "^0.19.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@astryxdesign/cli": "^0.1.6",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-singlefile": "^2.1.0"
  }
}
